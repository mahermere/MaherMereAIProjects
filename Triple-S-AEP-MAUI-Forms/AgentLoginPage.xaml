<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Triple_S_AEP_MAUI_Forms.AgentLoginPage"
             Title="Agent Login">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Triple-S Insurance"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="#0057A3" />

            <Label Text="Puerto Rico Agent Portal"
                   FontSize="16"
                   TextColor="#4A5568" />

            <VerticalStackLayout Spacing="8" Margin="0,20,0,0">
                <Label Text="Agent ID" />
                <Entry x:Name="AgentIdEntry"
                       Placeholder="Enter your Agent ID"
                       Keyboard="Text"
                       ClearButtonVisibility="WhileEditing" />

                <Label Text="Password" Margin="0,8,0,0" />
                <Entry x:Name="PasswordEntry"
                       Placeholder="Enter your password"
                       IsPassword="True"
                       ClearButtonVisibility="WhileEditing" />
            </VerticalStackLayout>

            <HorizontalStackLayout Spacing="10" Margin="0,8,0,0">
                <CheckBox x:Name="RememberMeCheckBox" />
                <Label Text="Remember me" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button x:Name="SignInButton"
                    Text="Sign In"
                    Margin="0,14,0,0"
                    HeightRequest="48"
                    BackgroundColor="#0057A3"
                    TextColor="White"
                    Clicked="OnSignInClicked" />

            <ActivityIndicator x:Name="SignInActivityIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#0057A3"
                               HorizontalOptions="Center" />

            <Label Text="For authorized Triple-S agents only."
                   FontSize="12"
                   TextColor="#718096"
                   Margin="0,8,0,0" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TripleSPOC.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TripleSPOC.Views"
    xmlns:local="clr-namespace:TripleSPOC"
    Title="TripleSPOC">

    <ShellContent
        Title="Agent Login"
        ContentTemplate="{DataTemplate views:AgentLoginPage}"
        Route="AgentLoginPage" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>

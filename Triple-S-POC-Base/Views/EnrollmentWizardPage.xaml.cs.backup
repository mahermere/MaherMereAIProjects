            };

            // Preload page 1 fields from CSV if available
            PreloadPage1FieldsFromCsv();

            // Refresh SOA dropdown from SOANumberService
            RefreshSOADropdown();
            SOANumberPicker.SelectedIndexChanged += SOANumberPicker_SelectedIndexChanged;
        }

        private readonly string soaFirstPageCsvPath = Path.Combine(FileSystem.Current.AppDataDirectory, "soa_firstpage_records.csv");

        private void PreloadPage1FieldsFromCsv()
        {
            var records = TripleS.Utilities.CsvDataUtility.LoadCsv(soaFirstPageCsvPath, TripleSPOC.Models.SOAFirstPageRecord.FromCsv);
            if (records.Count > 0)
            {
                var rec = records.Last(); // Use the most recent
                FirstNameBox.Text = rec.FirstName;
                LastNameBox.Text = rec.LastName;
                DOBPicker.Date = rec.DateOfBirth != DateTime.MinValue ? rec.DateOfBirth : DateTime.Today;
                GenderCombo.SelectedItem = rec.Gender;
                PrimaryPhoneBox.Text = rec.PrimaryPhone;
                MedicareBox.Text = rec.MedicareNumber;
            }
        }



        // Only one RefreshSOADropdown method, inside the class
        public void RefreshSOADropdown()
        {
            SOANumberPicker.ItemsSource = null;
            SOANumberPicker.ItemsSource = TripleS.SOA.AEP.UI.Services.SOANumberService.ActiveSOARecords
                .Select(r => $"{r.SOANumber} - {r.BeneficiaryName}").ToList();
        }
    
 
        private void SOANumberPicker_SelectedIndexChanged(object? sender, EventArgs e)
        {
            if (SOANumberPicker.SelectedIndex >= 0)
            {
                var selectedSOA = SOANumberPicker.SelectedItem as string;
                if (BindingContext is EnrollmentWizardViewModel vm)
                {
                    vm.SOANumber = selectedSOA;
                }
                
                // Auto-populate enrollment fields from SOA data
                PopulateFromSOA(selectedSOA);
            }
        }

        private void PopulateFromSOA(string? selectedSOA)
        {
            if (string.IsNullOrWhiteSpace(selectedSOA))
                return;

            try
            {
                // Extract SOA number from the format "SOANumber - BeneficiaryName"
                var soaNumber = selectedSOA.Split(" - ")[0].Trim();
                
                // Find the SOA record
                var soaRecord = TripleS.SOA.AEP.UI.Services.SOANumberService.ActiveSOARecords
                    .FirstOrDefault(r => r.SOANumber == soaNumber);
                
                if (soaRecord == null)
                {
                    System.Diagnostics.Debug.WriteLine($"SOA record not found: {soaNumber}");
                    return;
                }

                System.Diagnostics.Debug.WriteLine($"Populating enrollment from SOA: {soaNumber}");
                System.Diagnostics.Debug.WriteLine($"SOA Beneficiary: {soaRecord.FirstName} {soaRecord.LastName}");

                // Populate basic name fields from SOA record
                FirstNameBox.Text = soaRecord.FirstName;
                LastNameBox.Text = soaRecord.LastName;

                // Try to load additional details from soa_firstpage_records.csv
                var soaFirstPageRecords = TripleS.Utilities.CsvDataUtility.LoadCsv(
                    soaFirstPageCsvPath, 
                    TripleSPOC.Models.SOAFirstPageRecord.FromCsv);

                // Find matching record by first and last name
                var matchingRecord = soaFirstPageRecords.FirstOrDefault(r => 
                    r.FirstName.Equals(soaRecord.FirstName, StringComparison.OrdinalIgnoreCase) &&
                    r.LastName.Equals(soaRecord.LastName, StringComparison.OrdinalIgnoreCase));

                if (matchingRecord != null)
                {
                    System.Diagnostics.Debug.WriteLine($"Found matching SOA first page record");
                    
                    // Populate all available fields
                    if (matchingRecord.DateOfBirth != DateTime.MinValue)
                    {
                        DOBPicker.Date = matchingRecord.DateOfBirth;
                    }
                    
                    if (!string.IsNullOrWhiteSpace(matchingRecord.Gender))
                    {
                        // Try to match gender in the combo
                        var genderIndex = -1;
                        for (int i = 0; i < GenderCombo.Items.Count; i++)
                        {
                            if (GenderCombo.Items[i].Equals(matchingRecord.Gender, StringComparison.OrdinalIgnoreCase))
                            {
                                genderIndex = i;
                                break;
                            }
                        }
                        if (genderIndex >= 0)
                        {
                            GenderCombo.SelectedIndex = genderIndex;
                        }
                    }
                    
                    if (!string.IsNullOrWhiteSpace(matchingRecord.PrimaryPhone))
                    {
                        PrimaryPhoneBox.Text = matchingRecord.PrimaryPhone;
                    }
                    
                    if (!string.IsNullOrWhiteSpace(matchingRecord.MedicareNumber))
                    {
                        MedicareBox.Text = matchingRecord.MedicareNumber;
                    }

                    System.Diagnostics.Debug.WriteLine($"Enrollment fields populated successfully");
                    
                    // Show success message to user
                    MainThread.BeginInvokeOnMainThread(async () =>
                    {
                        var lang = LanguagePicker.SelectedIndex == 1 ? "es-PR" : "en";
                        await DisplayAlert(
                            lang == "es-PR" ? "Datos cargados" : "Data Loaded",
                            lang == "es-PR" 
                                ? $"Los datos del beneficiario de SOA {soaNumber} se han cargado en el formulario." 
                                : $"Beneficiary data from SOA {soaNumber} has been loaded into the form.",
                            "OK");
                    });
                }
                else
                {
                    System.Diagnostics.Debug.WriteLine($"No matching SOA first page record found for {soaRecord.FirstName} {soaRecord.LastName}");
                    
                    // Still show a message that basic info was loaded
                    MainThread.BeginInvokeOnMainThread(async () =>
                    {
                        var lang = LanguagePicker.SelectedIndex == 1 ? "es-PR" : "en";
                        await DisplayAlert(
                            lang == "es-PR" ? "Datos básicos cargados" : "Basic Data Loaded",
                            lang == "es-PR" 
                                ? $"Nombre del beneficiario cargado. Complete los campos restantes." 
                                : $"Beneficiary name loaded. Please complete remaining fields.",
                            "OK");
                    });
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error populating from SOA: {ex.Message}");
                System.Diagnostics.Debug.WriteLine($"Stack trace: {ex.StackTrace}");
                
                MainThread.BeginInvokeOnMainThread(async () =>
                {
                    var lang = LanguagePicker.SelectedIndex == 1 ? "es-PR" : "en";
                    await DisplayAlert(
                        lang == "es-PR" ? "Error" : "Error",
                        lang == "es-PR" 
                            ? $"Error al cargar datos de SOA: {ex.Message}" 
                            : $"Error loading SOA data: {ex.Message}",
                        "OK");
                });
            }
        }


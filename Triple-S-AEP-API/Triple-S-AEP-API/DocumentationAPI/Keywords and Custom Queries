foreach ( KeywordRecord keyRecord in document.KeywordRecords)
{

  // loop thru all keywords on each keyword record
  foreach (Keyword keyword in keyRecord.Keywords)
  { 

    // get the keyword type name and keyword value
    string name = keyword.KeywordType.Name;
    switch ( keyword.KeywordType.DataType)
    {
      case KeywordDataType.AlphaNumeric:
        string stringValue = keyword.AlphaNumericValue;
        break;
      case KeywordDataType.Currency:
      case KeywordDataType.SpecificCurrency:
        decimal currencyValue = keyword.CurrencyValue;
        break;
      case KeywordDataType.Date:
      case KeywordDataType.DateTime:
        DateTime datetimeValue = keyword.DateTimeValue;
        break;  
      case KeywordDataType.FloatingPoint:
        double floatingPointValue = keyword.FloatingPointValue;
        break;
      case KeywordDataType.Numeric20:
        decimal numeric20Value = keyword.Numeric20Value;
        break;
      case KeywordDataType.Numeric9:
        long numeric9alue = keyword.Numeric9Value;
        break;
    }
  }
}

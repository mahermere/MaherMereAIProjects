docQuery.RetrievalOptions = DocumentRetrievalOptions.LoadKeywords;

// Execute based on
DocumentList docList = docQuery.Execute(maxDocuments);
// or
QueryResult queryResults = docQuery.ExecuteQueryResults(maxDocuments);

// optionally set the retrieval options during the Execute() call
DocumentList docList = docQuery.Execute(maxDocuments, DocumentRetrievalOptions.LoadKeywords);
